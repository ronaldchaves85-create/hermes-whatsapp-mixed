# ==============================================================================
# 🔑 HERMES AGENT — Variáveis de Ambiente para Easypanel
# Cole o conteúdo abaixo na aba "Environment" do serviço no Easypanel
# ==============================================================================

# ------------------------------------------------------------------------------
# 🔒 SEGURANÇA & API (OBRIGATÓRIA)
# ------------------------------------------------------------------------------
API_SERVER_KEY=sua_chave_secreta_aqui

# ------------------------------------------------------------------------------
# 🤖 PROVEDORES DE IA (pelo menos uma é necessária)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ------------------------------------------------------------------------------
# 💬 TELEGRAM (Opcional)
# ------------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
GATEWAY_ALLOW_ALL_USERS=false

# ------------------------------------------------------------------------------
# 🟢 WHATSAPP (Opcional — mantenha false até parear o dispositivo)
# ------------------------------------------------------------------------------
WHATSAPP_ENABLED=false
WHATSAPP_OWNER_NUMBER=
WHATSAPP_MODE=bot
WHATSAPP_ALLOWED_USERS=*

# ------------------------------------------------------------------------------
# 🔑 GOOGLE CLOUD / OAUTH (Opcional)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# ⏱️ CONFIGURAÇÕES GERAIS (já possuem valores padrão)
# ------------------------------------------------------------------------------
TZ=America/Sao_Paulo
HERMES_API_TIMEOUT=1800
HERMES_API_CALL_STALE_TIMEOUT=300
API_SERVER_CORS_ORIGINS=*
