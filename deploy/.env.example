# 🔑 Chaves de API e Variáveis de Ambiente do Hermes Agent (.env)
# Renomeie este arquivo para .env (ou adicione as variáveis na Stack do Portainer)

# --- PROVEDORES DE IA (Pelo menos um é obrigatório) ---
# Se você for usar o OpenRouter (Recomendado pela variedade de modelos):
OPENROUTER_API_KEY=sua_chave_openrouter_aqui

# Se você preferir usar as chaves diretas dos provedores:
ANTHROPIC_API_KEY=sua_chave_anthropic_aqui
GOOGLE_API_KEY=sua_chave_gemini_aqui
DEEPSEEK_API_KEY=sua_chave_deepseek_aqui
OPENAI_API_KEY=sua_chave_openai_aqui

# --- INTEGRAÇÃO COM PLATAFORMAS (GATEWAY) ---
# Token do Bot do Telegram (se for usar Telegram)
TELEGRAM_BOT_TOKEN=seu_token_telegram_aqui

# Token e ID do Canal do Discord (se for usar Discord)
DISCORD_BOT_TOKEN=seu_token_discord_aqui
DISCORD_GUILD_ID=seu_id_servidor_discord_aqui

# --- INTEGRAÇÃO COM GMAIL (IMAP / SMTP) ---
# Para ler e responder e-mails de suporte automaticamente
# ATENÇÃO: Use uma "Senha de App" (App Password) gerada na sua Conta Google, e não sua senha pessoal!
EMAIL_USERNAME=seu_email_suporte@gmail.com
EMAIL_PASSWORD=sua_senha_de_app_de_16_digitos_aqui

# --- OUTROS RECURSOS ---
# Timezone para o agendamento de tarefas e logs
TZ=America/Sao_Paulo

# --- CONFIGURAÇÕES DE COMPORTAMENTO DO WHATSAPP ---
# Seu número pessoal do WhatsApp (Dono) para receber o menu administrativo e permissões
WHATSAPP_OWNER_NUMBER=5586981612061

# Modelos de IA para Dono e Clientes (Deixe em branco para usar o padrão Gemini 3.5 Flash)
WHATSAPP_OWNER_MODEL=gemini-3.5-flash
WHATSAPP_CLIENT_MODEL=gemini-3.5-flash

# Delay em segundos antes de enviar a PRIMEIRA resposta de um novo cliente (simula digitação humana)
WHATSAPP_FIRST_RESPONSE_DELAY_S=30
