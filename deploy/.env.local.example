# ==============================================================================
# Configuração do bot — copie este arquivo para ".env" na mesma pasta do
# docker-compose.local.yml e preencha os valores.
# ==============================================================================

# ── INDISPENSÁVEIS ────────────────────────────────────────────────────────────

# Chave secreta da API do Hermes — gere com: openssl rand -hex 32
# (ou invente uma senha longa aleatória, 64 caracteres)
API_SERVER_KEY=

# Chave do Google Gemini — crie grátis em https://aistudio.google.com
GOOGLE_API_KEY=

# Seu número de WhatsApp COM DDI e sem símbolos (ex: 5511999999999)
# É o número do DONO (você), não o do chip do bot.
WHATSAPP_OWNER_NUMBER=

# Seu primeiro nome (usado nos prompts do assistente)
WHATSAPP_OWNER_NAME=Hugo

# ── OPCIONAIS (pode deixar como está no início) ───────────────────────────────

# Deixe false até o momento de parear o QR Code; depois mude para true
WHATSAPP_ENABLED=true

# Nome da conexão exibido no Dashboard
WHATSAPP_CONNECTION_NAME=BotFinanceiro

TZ=America/Sao_Paulo

# ── INTEGRAÇÃO MK-AUTH (Fase 2 — deixe vazio por enquanto) ────────────────────

MKAUTH_URL=
MKAUTH_CLIENT_ID=
MKAUTH_CLIENT_SECRET=
MKAUTH_VERIFY_SSL=false
MKAUTH_SYNC_INTERVAL_H=6

# ── SINCRONIZAÇÃO DE CONFIGURAÇÃO VIA GITHUB (opcional) ───────────────────────
# Aponte para o SEU fork para o setup.sh baixar o plugin e as configurações.

HERMES_SETUP_GITHUB_USER=ronaldchaves85-create
CONFIG_REPO=
CONFIG_GITHUB_TOKEN=
